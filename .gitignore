.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Jupyter / notebook checkpoints
.ipynb_checkpoints/

# Generated analytics output
reports/
*.png
*.jpg

# IDE / OS cruft
.vscode/
.idea/
.DS_Store
Thumbs.db
