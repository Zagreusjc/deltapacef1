# ---------------------------------------------------------------------------
# DeltaPace :: Environment variable template
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in values for local development.
# Never commit `.env` — it is listed in `.gitignore`.
#
# Production: inject these variables via your deployment platform or populate
# them from AWS Secrets Manager *before* the Python process starts.
# ---------------------------------------------------------------------------

# --- AWS credentials (standard boto3 chain) ---------------------------------
# Option A: explicit keys (local dev only — prefer SSO or instance roles in prod)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=          # required for temporary/SSO credentials

# Option B: rely on ~/.aws/credentials, SSO, or EC2/ECS instance profile (recommended)
AWS_REGION=ap-southeast-1
# AWS_DEFAULT_REGION=ap-southeast-1   # fallback if AWS_REGION is unset

# --- DeltaPace S3 storage ---------------------------------------------------
# Bucket for processed artifacts and reports. Leave empty to run fully local.
DELTAPACE_S3_BUCKET=
DELTAPACE_S3_PREFIX=deltapace

# Force S3 on even when credential auto-detection is ambiguous (true/false)
DELTAPACE_USE_S3=false

# --- Amazon Bedrock (narrative report step) ---------------------------------
# Model ID for the Bedrock Converse API (Claude Haiku is a cost-effective default)
DELTAPACE_BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Skip Bedrock calls and emit a local template report (true/false)
DELTAPACE_MOCK_LLM=true

# Explicit CI flag — also forces mock_mode for Bedrock (true/false)
DELTAPACE_CI=false

# --- Optional: default race context (overridden by CLI later) ---------------
# DELTAPACE_YEAR=2023
# DELTAPACE_GP=Bahrain
# DELTAPACE_SESSION=R
